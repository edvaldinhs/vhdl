LIBRARY IEEE;
USE IEEE.STD_LOGIC_1164.ALL;
USE IEEE.NUMERIC_STD.ALL;

ENTITY tb_top_level_media IS
END tb_top_level_media;

ARCHITECTURE sim OF tb_top_level_media IS
    -- Sinais do Stimulus
    SIGNAL clk        : STD_LOGIC := '0';
    SIGNAL rst_n      : STD_LOGIC := '1'; -- KEY(3)
    SIGNAL btn_start  : STD_LOGIC := '1'; -- KEY(0)
    SIGNAL switches   : STD_LOGIC_VECTOR(15 DOWNTO 0) := (OTHERS => '0');
    SIGNAL addr_sig   : STD_LOGIC_VECTOR(1 DOWNTO 0) := "00";
    
    -- Vetor intermediário estático para os botões
    SIGNAL s_keys     : STD_LOGIC_VECTOR(3 DOWNTO 0);
    
    -- Saídas da Placa
    SIGNAL hex0, hex1, hex2, hex3 : STD_LOGIC_VECTOR(6 DOWNTO 0);
    SIGNAL led_pronto : STD_LOGIC_VECTOR(0 DOWNTO 0);
    SIGNAL saida_reg  : STD_LOGIC_VECTOR(15 DOWNTO 0);
    SIGNAL op_state   : STD_LOGIC_VECTOR(1 DOWNTO 0);

    CONSTANT CLK_PERIOD : TIME := 20 ns; -- 50 MHz
BEGIN
    -- Agrupamento estático dos botões (Mantemos KEY(2) e KEY(1) em '1' pois não são usados na média automática)
    s_keys <= (rst_n & '1' & '1' & btn_start);

    -- Instanciação do circuito completo (UUT)
    uut: ENTITY work.top_level
        PORT MAP (
            CLOCK_50 => clk,
            SW       => switches,
            KEY      => s_keys,
            ADDR     => addr_sig,
            SAIDA    => saida_reg,
            OP_S     => op_state,
            HEX0     => hex0, 
            HEX1     => hex1, 
            HEX2     => hex2, 
            HEX3     => hex3,
            LEDG     => led_pronto
        );

    -- Gerador do clock
    clk_process : PROCESS
    BEGIN
        clk <= '0'; WAIT FOR CLK_PERIOD/2;
        clk <= '1'; WAIT FOR CLK_PERIOD/2;
    END PROCESS;

    stim_proc: PROCESS
    BEGIN
        -- Passo 1: Reset inicial do sistema (Equivalente a pressionar KEY(3))
        rst_n <= '0';
        WAIT FOR CLK_PERIOD * 2;
        rst_n <= '1';
        WAIT FOR CLK_PERIOD * 5;

        ------------------------------------------------------------
        -- TESTE: Calcular a Média entre X (Matrícula) e Y
        -- Assumindo que o X no seu PO_Media seja 1234 (x"04D2").
        -- Vamos usar Y = 1000. Média esperada: (1234 + 1000) / 2 = 1117.
        ------------------------------------------------------------
        
        -- Passo 2: Pressionar Start para exibir a Constante X
        -- A máquina sairá do S_IDLE e irá para S_WAIT_X
        btn_start <= '0'; WAIT FOR CLK_PERIOD * 2; btn_start <= '1';
        WAIT FOR CLK_PERIOD * 10; -- Tempo lendo o display na vida real

        -- Passo 3: Inserir o valor de Y nas chaves e pressionar Start
        switches <= STD_LOGIC_VECTOR(to_unsigned(1000, 16)); -- Y = 1000
        WAIT FOR CLK_PERIOD * 2;
        
        -- A máquina sairá do S_WAIT_X e irá para S_WAIT_Y
        btn_start <= '0'; WAIT FOR CLK_PERIOD * 2; btn_start <= '1';
        WAIT FOR CLK_PERIOD * 10; -- Tempo conferindo o Y no display na vida real

        -- Passo 4: Pressionar Start para Calcular a Média
        -- A máquina sairá do S_WAIT_Y, fará o cálculo e irá para S_WAIT_RES
        btn_start <= '0'; WAIT FOR CLK_PERIOD * 2; btn_start <= '1';
        
        -- Passo 5: Aguardar o circuito sinalizar que terminou e estabilizar
        WAIT UNTIL led_pronto(0) = '1';
        WAIT FOR CLK_PERIOD * 10;
        
        -- Se você mudar a exibição do sinal "saida_reg" para "Unsigned Decimal" no ModelSim,
        -- você deverá ver exatamente o valor 1117 cravado nele ao final do teste.

        ASSERT FALSE REPORT "Fim da simulacao da Media com sucesso!" SEVERITY FAILURE;
    END PROCESS;
END sim;